# =============================================================================
# ~/.gitignore - Dotfiles Repository
# =============================================================================
# Purpose: Track portable configs, exclude machine-specific paths and secrets

# ----------------------------------------------------------------------------
# Secrets & Credentials (NEVER COMMIT)
# ----------------------------------------------------------------------------
*.pem
*.key
*.crt
.netrc
.npmrc
.pypirc
.git-credentials
*.enc.env
secrets/
credentials.json

# ----------------------------------------------------------------------------
# Machine-Specific Paths (Use ~/ instead)
# ----------------------------------------------------------------------------
# If you see absolute paths like /home/miko/, make them relative

# ----------------------------------------------------------------------------
# OS-Specific Files
# ----------------------------------------------------------------------------
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Editor/IDE
# ----------------------------------------------------------------------------
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# ----------------------------------------------------------------------------
# Logs & Temp Files
# ----------------------------------------------------------------------------
*.log
logs/
tmp/
.cache/

# ----------------------------------------------------------------------------
# Compiled/Generated
# ----------------------------------------------------------------------------
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# ----------------------------------------------------------------------------
# Node/npm (if bin/ has tooling)
# ----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock

# ----------------------------------------------------------------------------
# Stow/Install Artifacts
# ----------------------------------------------------------------------------
# The install script should be clean, but just in case
*.bak
*.backup

# ----------------------------------------------------------------------------
# Local Overrides (User-Specific, Not Tracked)
# ----------------------------------------------------------------------------
.zshrc.local
.bashrc.local
.condarc.local
.gitconfig.local
.localrc
.extra

# Keep tracked bin scripts even when global gitignore excludes .local/
!bin/.local/
!bin/.local/bin/
!bin/.local/bin/dotfiles-doctor
